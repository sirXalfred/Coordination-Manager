{
	"private": true,
	"description": "Coordination Manager workspace root — see Code/ for the monorepo",
	"scripts": {
		"dev": "pnpm --dir ./Code dev",
		"dev:web": "pnpm --dir ./Code dev:web",
		"dev:api": "pnpm --dir ./Code dev:api",
		"dev:bot": "pnpm --dir ./Code dev:bot",
		"dev:guardian": "pnpm --dir ./Code dev:guardian",
		"dev:docs": "pnpm --dir ./Code dev:docs",
		"dev:stack": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
		"dev:stack:no-check": "powershell -ExecutionPolicy Bypass -File ./start.ps1 -SkipHealthCheck",
		"dev:health": "powershell -ExecutionPolicy Bypass -File ./check-health.ps1",
		"dev:stop": "node ./Code/scripts/stop-servers.js",
		"build": "pnpm --dir ./Code build",
		"test": "pnpm --dir ./Code test",
		"lint": "pnpm --dir ./Code lint",
		"typecheck": "pnpm --dir ./Code typecheck",
		"format": "pnpm --dir ./Code format",
		"security:check": "powershell -ExecutionPolicy Bypass -File ./scripts/security-check.ps1",
		"security:check:full-history": "powershell -ExecutionPolicy Bypass -File ./scripts/security-check.ps1 -GitleaksFullHistory",
		"security:check:fast": "powershell -ExecutionPolicy Bypass -File ./scripts/security-check.ps1 -SkipMonorepoTests -SkipGitleaks"
	},
	"devDependencies": {
		"tsx": "^4.21.0"
	}
}
