# Swarm Coordinator Discord Bot
# Copy this file to .env and fill in the values

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Supabase connection (same as API server)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Internal API authentication (REQUIRED — must match API server's BOT_API_SECRET)
BOT_API_SECRET=your_secure_random_secret_here
BOT_API_PORT=3002

# API server URL (bot delegates email sending to the API)
API_URL=http://localhost:3001

# Frontend URL (used in bot messages to link users back to the web app)
FRONTEND_URL=http://localhost:5173