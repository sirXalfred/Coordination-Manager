{
  "name": "@coordination-manager/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js",
    "build": "tsc && vite build",
    "build:with-docs": "tsc && vite build && cd ../docs && pnpm run build && cd ../web && node scripts/copy-docs.js",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.2",
    "@supabase/supabase-js": "^2.90.1",
    "@tiptap/extension-details": "^3.26.0",
    "@tiptap/extension-list": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "axios": "^1.16.0",
    "date-fns": "^3.0.6",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/node": "^25.9.2",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  }
}
