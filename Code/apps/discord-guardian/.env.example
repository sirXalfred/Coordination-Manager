# Demon X — Environment Variables

# Discord Bot Token (from Discord Developer Portal — separate bot application)
DISCORD_BOT_TOKEN=your_guardian_bot_token_here

# Discord Application ID (from the same bot application)
DISCORD_CLIENT_ID=your_guardian_client_id_here

# Supabase connection (same as API server — shared database)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Set to 'true' to skip Discord login (use when running local dev and production bot is active)
DISABLE_BOT=false
