{
  "name": "@coordination-manager/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:server": "vitest --run src/__tests__/public-server/",
    "test:public": "vitest --run --config vitest.public.config.ts",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@meshsdk/core": "^1.9.0-beta.98",
    "@supabase/supabase-js": "^2.39.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^7.1.0",
    "ical-expander": "^3.2.0",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^7.0.11",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "supertest": "^7.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
