# Database (DATABASE_URL is only used for running migrations via psql, not by the app runtime)
DATABASE_URL=your_supabase_connection_string
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth & Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/calendar-sources/google/callback

# Discord (Coordinator Bot)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id

# Discord Guardian Bot (separate bot application)
GUARDIAN_BOT_TOKEN=your_guardian_bot_token
GUARDIAN_CLIENT_ID=your_guardian_client_id

# Bot-to-API internal communication (REQUIRED — no fallback default)
BOT_API_URL=http://localhost:3002
BOT_API_SECRET=your_secure_random_secret_here

# Authentication
JWT_SECRET=your_jwt_secret
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# AI — Primary model (OpenAI)
AI_PROVIDER=openai
AI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4o
# AI_BASE_URL=https://api.openai.com/v1   (auto-set when AI_PROVIDER=openai)

# AI — ASI-1 Mini (optional, enables per-user model switching)
ASI_API_KEY=your_asi_api_key
# ASI_BASE_URL=https://api.asi1.ai/v1
# ASI_MODEL=asi1-mini

# Zoom OAuth (create app at https://marketplace.zoom.us → Develop → Build App → OAuth)
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URI=http://localhost:3001/api/zoom/callback

# Figma (Personal Access Token — generate at Figma > Settings > Personal access tokens)
# Required scopes: current_user:read, file_content:read, file_comments:write, projects:read
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token
FIGMA_TEAM_ID=your_figma_team_id

# Email / SMTP — platform default sender
# Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=coreswarm@gmail.com
SMTP_PASS=your_gmail_app_password
# 32-byte key (64 hex chars) for encrypting per-user SMTP passwords in the database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SMTP_ENCRYPTION_KEY=your_64_hex_char_encryption_key