# Coordination Manager Agent API
COORDINATION_API_URL=http://localhost:3001
COORDINATION_API_KEY=your-agent-api-key-here

# uAgent identity
AGENT_SEED=your-secret-seed-phrase-here
AGENT_PORT=8001

# Optional: Agentverse mailbox key (for remote accessibility)
# AGENTVERSE_MAILBOX_KEY=your-mailbox-key

# ASI:Create Langflow integration
LANGFLOW_BASE_URL=https://lfproxy.singularitynet.io/your-agent-id
